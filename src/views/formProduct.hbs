<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-12 col-md-8 col-lg-6">

      <div class="card shadow-sm">
        <div class="card-body p-4">

          <h3 class="card-title text-center mb-4">
            Agregar Producto
          </h3>

          <form action="/create-product" method="POST">

            <!-- Nombre -->
            <div class="mb-3">
              <label class="form-label">Nombre del Producto</label>
              <input type="text" name="title" class="form-control" required placeholder="Ej. Monitor">
            </div>

            <!-- Descripción -->
            <div class="mb-3">
              <label class="form-label">Descripción</label>
              <textarea name="description" rows="4" class="form-control"
                placeholder="¿De qué trata este producto?"></textarea>
            </div>

            <!-- Precio -->
            <div class="mb-3">
              <label class="form-label">Precio (USD)</label>
              <input type="number" step="0.01" name="price" class="form-control" required placeholder="Ej. 49.99">
            </div>

            <!-- Categoría -->
            <div class="mb-3">
              <label class="form-label">Categoría</label>

              <div class="d-flex gap-2">
                <select name="categoryId" required class="form-select">
                  <option value="" disabled selected>
                    -- Selecciona una categoría --
                  </option>
                  {{#each categories}}
                  <option value="{{this.id}}">{{this.name}}</option>
                  {{/each}}
                </select>

                <a href="/create-category" class="btn btn-primary">
                  Nueva Categoría
                </a>
              </div>

              {{#unless categories.length}}
              <small class="text-danger">
                No hay categorías, debes crear una.
              </small>
              {{/unless}}
            </div>

            <button type="submit" class="btn btn-success w-100 mt-3">
              Guardar producto
            </button>

          </form>

          <div class="text-center mt-4">
            <a href="/" class="link-secondary text-decoration-none">
              ⬅ Volver al catálogo
            </a>
          </div>

        </div>
      </div>

    </div>
  </div>
</div>